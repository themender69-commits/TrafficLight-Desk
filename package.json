{
  "name": "trafficlight-desk",
  "version": "0.1.0",
  "description": "AI 工具状态监视器 — 桌面红绿灯",
  "main": "main.cjs",
  "author": "TrafficLight Desk",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE TRAFFICLIGHT_DEV=1 electron .\"",
    "build": "vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "preview": "vite build && env -u ELECTRON_RUN_AS_NODE electron .",
    "dist": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder",
    "dist:mac": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac",
    "dist:win": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder --win"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "desk.trafficlight.app",
    "productName": "TrafficLight Desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "cursor-hooks",
        "to": "cursor-hooks",
        "filter": [
          "**/*.sh"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "artifactName": "TrafficLight-Desk-${version}-mac.${ext}"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "TrafficLight-Desk-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "TrafficLight-Desk-${version}-portable.${ext}"
    }
  }
}
